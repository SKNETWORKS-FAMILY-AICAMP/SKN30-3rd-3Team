# Shared
APP_ENV=local
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Frontend public values only
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend secrets: never expose these to frontend
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_AUDIENCE=authenticated

# LLM / RAG
OPENAI_API_KEY=
CHAT_MODEL=
VISION_MODEL=
EMBEDDING_MODEL=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=plant-doctor-rag

# Public agricultural data APIs
NONGSARO_API_KEY=
RDA_API_KEY=
WEATHER_API_KEY=

# Object storage for uploaded plant images and source documents
OBJECT_STORAGE_BUCKET=plant-doctor
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
